{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users including clients, workers, labs, pharmacies, and admins",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "worker", "lab", "pharmacy", "admin", "hospital", "doctor"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "language": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Worker": {
      "title": "Worker",
      "description": "Service provider details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "category": { "type": "string", "description": "Legacy field for single service" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "pricing": {
                "type": "object",
                "properties": {
                  "perVisit": { "type": "number" },
                  "perDay": { "type": "number" },
                  "monthly": { "type": "number" }
                }
              }
            }
          }
        },
        "experience": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "location": { "type": "object" },
        "currentLocation": { "type": "object" },
        "rating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "paid"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "freeClientsUsed": { "type": "number" },
        "pricePerHour": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive", "blocked"] },
        "isFeatured": { "type": "boolean" },
        "boostExpiry": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "experience", "gender"]
    },
    "BusinessProvider": {
      "title": "BusinessProvider",
      "description": "Lab, Pharmacy, or Hospital details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["lab", "pharmacy", "hospital"] },
        "location": { "type": "object" },
        "contact": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["uid", "name", "type"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "hospitalId": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "fee": { "type": "number" },
        "videoFee": { "type": "number" },
        "rating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "freeAppointmentsRemaining": { "type": "number" },
        "videoConsultationAvailable": { "type": "boolean" },
        "bio": { "type": "string" },
        "certificates": { "type": "array", "items": { "type": "string" } },
        "photo": { "type": "string" },
        "isTopDoctor": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "specialty", "fee"]
    },
    "DoctorSchedule": {
      "title": "DoctorSchedule",
      "description": "Doctor availability schedule",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "availabilityType": { "type": "string", "enum": ["OPD", "OT", "Leave", "Not Available"] },
        "timeSlots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" },
              "isBooked": { "type": "boolean" },
              "bookingId": { "type": "string" }
            }
          }
        }
      },
      "required": ["doctorId", "date", "availabilityType"]
    },
    "DoctorAppointment": {
      "title": "DoctorAppointment",
      "description": "Doctor appointment booking details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "familyMemberId": { "type": "string" },
        "hospitalId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "object" },
        "type": { "type": "string", "enum": ["prepaid", "postpaid"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "isEmergency": { "type": "boolean" },
        "isVideo": { "type": "boolean" },
        "amount": { "type": "number" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "notes": { "type": "string" },
        "prescriptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "doctorId", "date", "timeSlot", "amount"]
    },
    "DigitalPrescription": {
      "title": "Digital Prescription",
      "description": "Digital prescription details",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "doctorId": { "type": "string" },
        "userId": { "type": "string" },
        "patientName": { "type": "string" },
        "diagnosis": { "type": "string" },
        "vitals": { "type": "object" },
        "medicines": { "type": "array" },
        "advice": { "type": "string" },
        "followUpDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "doctorId", "userId", "patientName", "diagnosis", "medicines", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "workerId": { "type": "string" },
        "serviceType": { "type": "string" },
        "timing": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "refunded"] },
        "amount": { "type": "number" },
        "commission": { "type": "number" },
        "workerShare": { "type": "number" },
        "cancellationReason": { "type": "string" },
        "refundId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "workerId", "serviceType", "amount"]
    },
    "PrescriptionOrder": {
      "title": "PrescriptionOrder",
      "description": "Medicine order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pharmacyId": { "type": "string" },
        "prescriptionPhotos": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "accepted", "delivered", "cancelled"] },
        "amount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "paymentMethod": { "type": "string", "enum": ["upi", "card", "cod"] }
      },
      "required": ["userId", "prescriptionPhotos"]
    },
    "LabRequest": {
      "title": "LabRequest",
      "description": "Lab sample collection details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "labId": { "type": "string" },
        "testType": { "type": "string" },
        "timing": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "collected", "completed", "cancelled"] }
      },
      "required": ["userId", "testType", "timing"]
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "Payment verification details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "providerId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["upi", "card", "cod"] },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] }
      },
      "required": ["userId", "providerId", "amount", "method"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session between user and provider",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "bookingId": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["booking", "payment", "chat", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Service invoices",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "userId": { "type": "string" },
        "workerId": { "type": "string" },
        "amount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "userId", "workerId", "amount", "total"]
    },
    "CashfreeTransaction": {
      "title": "CashfreeTransaction",
      "description": "Cashfree payment transaction details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "cfOrderId": { "type": "string" },
        "userId": { "type": "string" },
        "bookingId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED", "PENDING", "CANCELLED", "FLAGGED"] },
        "paymentMode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "amount", "status"]
    },
    "RefundRecord": {
      "title": "RefundRecord",
      "description": "Payment refund details",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "orderId": { "type": "string" },
        "refundId": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["INITIATED", "PROCESSING", "SUCCESS", "FAILED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "orderId", "refundId", "amount", "reason", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/workers/{uid}": {
      "schema": "Worker",
      "description": "Worker profiles"
    },
    "/business_providers/{uid}": {
      "schema": "BusinessProvider",
      "description": "Lab and Pharmacy profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    },
    "/prescription_orders/{orderId}": {
      "schema": "PrescriptionOrder",
      "description": "Medicine orders"
    },
    "/lab_requests/{requestId}": {
      "schema": "LabRequest",
      "description": "Lab sample collection requests"
    },
    "/payment_requests/{paymentId}": {
      "schema": "PaymentRequest",
      "description": "Payment verification requests"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications"
    },
    "/doctors/{uid}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "/doctor_schedules/{scheduleId}": {
      "schema": "DoctorSchedule",
      "description": "Doctor availability schedules"
    },
    "/doctor_appointments/{appointmentId}": {
      "schema": "DoctorAppointment",
      "description": "Doctor appointment bookings"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Service invoices"
    },
    "/cashfree_transactions/{transactionId}": {
      "schema": "CashfreeTransaction",
      "description": "Cashfree payment transactions"
    },
    "/refund_records/{refundId}": {
      "schema": "RefundRecord",
      "description": "Payment refunds"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "DigitalPrescription",
      "description": "Digital prescriptions generated by doctors"
    }
  }
}
